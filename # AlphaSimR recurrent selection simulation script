cat("ALPHASIMR RECURRENT SIMULATION COMPLETED SUCCESSFULLY\n")
cat("============================================================\n")

cat("\nFiles saved:\n")
cat("- AlphaSimR_cycle_summary_recorrente.rds\n")
cat("- AlphaSimR_cycle_summary_recorrente.csv\n")
cat("- AlphaSimR_elites_recorrente.rds\n")
cat("- AlphaSimR_elites_recorrente.csv\n")
cat("- AlphaSimR_TC_selected_recorrente.rds\n")
cat("- AlphaSimR_TC_selected_recorrente.csv\n")
cat("- AlphaSimR_crosses_used_recorrente.rds\n")
